<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础应用主题 -->
    <style name="Theme.StalkerPanel" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 主色 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>

        <!-- 状态栏 -->
        <item name="android:statusBarColor">@color/primary_dark</item>

        <!-- 背景 -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- 文字 -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- 主题覆盖：深色模式 -->
    <style name="Theme.StalkerPanel.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowBackground">@color/gray_900</item>
    </style>

    <!-- Toolbar 样式 -->
    <style name="StalkerToolbar" parent="Widget.Material3.Toolbar.Surface">
        <item name="titleTextColor">@color/white</item>
        <item name="android:background">@color/primary</item>
        <item name="titleTextAppearance">@style/TextAppearance.Stalker.Toolbar</item>
    </style>

    <style name="TextAppearance.Stalker.Toolbar" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 卡片样式 -->
    <style name="StalkerCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- 功能开关项样式 -->
    <style name="FeatureItemContainer">
        <item name="android:padding">16dp</item>
        <item name="android:background">?selectableItemBackground</item>
    </style>

    <style name="FeatureItemTitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="FeatureItemDesc" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- 状态指示器 -->
    <style name="StatusDot">
        <item name="android:width">10dp</item>
        <item name="android:height">10dp</item>
    </style>

    <!-- 按钮样式 -->
    <style name="StalkerButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="StalkerButtonOutlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/primary</item>
    </style>

    <style name="StalkerButtonDanger" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/status_disconnected</item>
    </style>
</resources>
